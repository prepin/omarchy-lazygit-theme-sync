#!/bin/bash

set -euo pipefail

VERSION="1.0.0"

# Paths
PKG_DIR="/usr/share/omarchy-lazygit-theme-sync"
USER_BIN_DIR="$HOME/.local/bin"
USER_CONFIG_DIR="$HOME/.config/omarchy"
USER_LAZYGIT_DIR="$HOME/.config/lazygit"
USER_LAZYGIT_THEMES_DIR="$USER_CONFIG_DIR/lazygit-themes"
OMARCHY_HOOKS_DIR="$USER_CONFIG_DIR/hooks"
HOOK_FILE="$OMARCHY_HOOKS_DIR/theme-set"
SKIP_FILE="$USER_CONFIG_DIR/toggles/skip-lazygit-theme"
THEME_NAME_FILE="$USER_CONFIG_DIR/current/theme.name"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() {
    echo -e "${BLUE}[INFO]${NC} $*"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $*"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $*"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $*" >&2
}

# Check if PATH contains ~/.local/bin before /usr/bin
check_path() {
    case ":$PATH:" in
        *:"$USER_BIN_DIR":*)
            # Check if it's before /usr/bin
            if [[ "$PATH" =~ "$USER_BIN_DIR"[^\:]*usr/bin ]]; then
                return 0
            else
                log_warn "$USER_BIN_DIR is in PATH but after /usr/bin"
                log_warn "System lazygit may take precedence"
                return 1
            fi
            ;;
        *)
            log_error "$USER_BIN_DIR is not in PATH"
            log_error "The wrapper won't be found by the shell"
            log_error "Add it to your PATH or ensure Omarchy is installed"
            return 1
            ;;
    esac
}

setup() {
    log_info "Setting up Omarchy Lazygit Theme Sync..."
    echo ""

    # Check PATH
    check_path || {
        echo ""
        log_error "PATH check failed. Please fix your PATH before continuing."
        log_error "Ensure ~/.local/bin is before /usr/bin in your PATH."
        exit 1
    }

    # Create directories
    log_info "Creating directories..."
    mkdir -p "$USER_BIN_DIR"
    mkdir -p "$USER_LAZYGIT_DIR"
    mkdir -p "$USER_LAZYGIT_THEMES_DIR"
    mkdir -p "$OMARCHY_HOOKS_DIR"

    # Install wrapper
    log_info "Installing lazygit wrapper..."
    if [[ -f "$PKG_DIR/lazygit-wrapper" ]]; then
        cp "$PKG_DIR/lazygit-wrapper" "$USER_BIN_DIR/lazygit"
        chmod +x "$USER_BIN_DIR/lazygit"
        log_success "Installed wrapper to $USER_BIN_DIR/lazygit"
    else
        log_error "Wrapper not found at $PKG_DIR/lazygit-wrapper"
        exit 1
    fi

    # Copy bundled themes
    log_info "Copying bundled themes..."
    if [[ -d "$PKG_DIR/themes" ]]; then
        cp "$PKG_DIR/themes"/*.yml "$USER_LAZYGIT_THEMES_DIR/"
        log_success "Copied themes to $USER_LAZYGIT_THEMES_DIR"
    else
        log_error "Themes directory not found at $PKG_DIR/themes"
        exit 1
    fi

    # Install hook
    log_info "Installing Omarchy hook..."
    install_hook

    # Apply initial theme
    log_info "Applying initial theme..."
    apply_current_theme

    echo ""
    log_success "Setup complete!"
    echo ""
    log_success "🎉 Omarchy Lazygit Theme Sync is ready!"
    log_info "Change your Omarchy theme and lazygit will follow along automatically!"
    echo ""
}

install_hook() {
    local hook_marker_start="# >>> omarchy-lazygit-theme-sync hook >>>"
    local hook_marker_end="# <<< omarchy-lazygit-theme-sync hook <<<"
    local hook_command='/usr/bin/omarchy-lazygit-theme-sync apply "$1"'

    # Remove old hook if exists
    if [[ -f "$HOOK_FILE" ]]; then
        if grep -q "$hook_marker_start" "$HOOK_FILE" 2>/dev/null; then
            sed -i "/$hook_marker_start/,/$hook_marker_end/d" "$HOOK_FILE"
            log_info "Removed old hook"
        fi
    else
        # Create hook file with shebang
        cat > "$HOOK_FILE" << 'EOF'
#!/bin/bash
# This hook is called with the snake-cased name of the theme that has just been set.
EOF
        chmod +x "$HOOK_FILE"
        log_info "Created hook file"
    fi

    # Add new hook
    cat >> "$HOOK_FILE" << EOF

$hook_marker_start
# Apply lazygit theme on Omarchy theme change
$hook_command
$hook_marker_end
EOF

    chmod +x "$HOOK_FILE"
    log_success "Installed hook to $HOOK_FILE"
}

apply() {
    local theme_name="$1"

    if [[ -z "$theme_name" ]]; then
        log_error "Theme name required"
        log_error "Usage: $0 apply <theme-name>"
        exit 1
    fi

    # Check if skipped
    if [[ -f "$SKIP_FILE" ]]; then
        log_info "Lazygit theme sync is disabled (skip file exists)"
        exit 0
    fi

    # Call the apply script
    if [[ -x "/usr/bin/omarchy-lazygit-theme-apply.sh" ]]; then
        /usr/bin/omarchy-lazygit-theme-apply.sh "$theme_name"
        log_success "Applied lazygit theme: $theme_name"
    else
        log_error "Apply script not found: /usr/bin/omarchy-lazygit-theme-apply.sh"
        exit 1
    fi
}

sync() {
    log_info "Syncing lazygit theme with current Omarchy theme..."

    # Get current theme
    local theme_name=""
    if [[ -f "$THEME_NAME_FILE" ]]; then
        theme_name=$(cat "$THEME_NAME_FILE" 2>/dev/null | tr -d '\n\r' || echo "")
    fi

    if [[ -z "$theme_name" ]]; then
        log_warn "Could not determine current Omarchy theme"
        log_warn "Using 'catppuccin' as fallback"
        theme_name="catppuccin"
    fi

    apply "$theme_name"
}

apply_current_theme() {
    sync
}

uninstall() {
    log_info "Uninstalling Omarchy Lazygit Theme Sync..."
    echo ""

    # Remove wrapper
    log_info "Removing lazygit wrapper..."
    if [[ -f "$USER_BIN_DIR/lazygit" ]]; then
        rm "$USER_BIN_DIR/lazygit"
        log_success "Removed $USER_BIN_DIR/lazygit"
    fi

    # Remove themes
    log_info "Removing bundled themes..."
    if [[ -d "$USER_LAZYGIT_THEMES_DIR" ]]; then
        rm -rf "$USER_LAZYGIT_THEMES_DIR"
        log_success "Removed $USER_LAZYGIT_THEMES_DIR"
    fi

    # Remove hook
    log_info "Removing Omarchy hook..."
    if [[ -f "$HOOK_FILE" ]]; then
        local hook_marker_start="# >>> omarchy-lazygit-theme-sync hook >>>"
        local hook_marker_end="# <<< omarchy-lazygit-theme-sync hook <<<"

        if grep -q "$hook_marker_start" "$HOOK_FILE" 2>/dev/null; then
            sed -i "/$hook_marker_start/,/$hook_marker_end/d" "$HOOK_FILE"
            log_success "Removed hook from $HOOK_FILE"

            # Remove empty hook file
            if [[ ! -s "$HOOK_FILE" ]] || [[ $(wc -l < "$HOOK_FILE") -eq 1 ]]; then
                rm "$HOOK_FILE"
                log_success "Removed empty hook file"
            fi
        else
            log_info "No hook found in $HOOK_FILE"
        fi
    fi

    # Note: We don't remove ~/.config/lazygit/theme.yml as it may have been manually configured

    echo ""
    log_success "Uninstall complete!"
    echo ""
    log_info "Note: ~/.config/lazygit/theme.yml was preserved"
    log_info "      Remove it manually if desired"
    echo ""
}

status() {
    log_info "Omarchy Lazygit Theme Sync Status"
    echo ""

    # Check installation
    log_info "Installation:"
    if [[ -f "$USER_BIN_DIR/lazygit" ]]; then
        log_success "  ✓ Wrapper installed: $USER_BIN_DIR/lazygit"
    else
        log_error "  ✗ Wrapper not found"
    fi

    if [[ -d "$USER_LAZYGIT_THEMES_DIR" ]]; then
        local theme_count=$(ls -1 "$USER_LAZYGIT_THEMES_DIR"/*.yml 2>/dev/null | wc -l)
        log_success "  ✓ Themes installed: $theme_count themes in $USER_LAZYGIT_THEMES_DIR"
    else
        log_error "  ✗ Themes directory not found"
    fi

    # Check hook
    log_info "Omarchy Hook:"
    if [[ -f "$HOOK_FILE" ]]; then
        if grep -q "omarchy-lazygit-theme-sync" "$HOOK_FILE" 2>/dev/null; then
            log_success "  ✓ Hook installed: $HOOK_FILE"
        else
            log_warn "  ✗ Hook exists but not configured"
        fi
    else
        log_error "  ✗ Hook file not found"
    fi

    # Check PATH
    log_info "PATH:"
    check_path && log_success "  ✓ PATH configured correctly" || log_warn "  ✗ PATH needs fixing"

    # Check skip status
    log_info "Sync Status:"
    if [[ -f "$SKIP_FILE" ]]; then
        log_warn "  ⚠ Sync disabled (skip file exists)"
    else
        log_success "  ✓ Sync enabled"
    fi

    # Current theme
    log_info "Current Theme:"
    if [[ -f "$THEME_NAME_FILE" ]]; then
        local current_theme=$(cat "$THEME_NAME_FILE" 2>/dev/null || echo "unknown")
        log_info "  $current_theme"
    else
        log_warn "  Could not determine"
    fi

    echo ""
}

version() {
    echo "omarchy-lazygit-theme-sync v$VERSION"
}

usage() {
    cat << EOF
Omarchy Lazygit Theme Sync v$VERSION

USAGE:
    $0 [COMMAND]

COMMANDS:
    setup       Set up lazygit wrapper, themes, and Omarchy hooks
    apply       Apply lazygit theme by name (used by Omarchy hook)
    sync        Sync lazygit theme with current Omarchy theme
    uninstall   Remove wrapper, themes, and hooks
    status      Show installation status
    version     Show version

OPTIONS:
    -h, --help  Show this help

EXAMPLES:
    $0 setup                           # Set up everything
    $0 apply catppuccin                # Apply catppuccin theme
    $0 sync                            # Sync with current theme
    $0 status                          # Check status
    $0 uninstall                       # Remove installation

FILES:
    ~/.local/bin/lazygit               # Wrapper script
    ~/.config/omarchy/lazygit-themes/  # Bundled themes
    ~/.config/omarchy/hooks/theme-set  # Omarchy hook
    ~/.config/lazygit/theme.yml        # Generated theme

EOF
}

main() {
    local command=""

    if [[ $# -eq 0 ]]; then
        usage
        exit 0
    fi

    case "$1" in
        setup)
            setup
            ;;
        apply)
            shift
            apply "$@"
            ;;
        sync)
            sync
            ;;
        uninstall)
            uninstall
            ;;
        status)
            status
            ;;
        version|--version|-v)
            version
            ;;
        help|--help|-h)
            usage
            ;;
        *)
            log_error "Unknown command: $1"
            echo ""
            usage
            exit 1
            ;;
    esac
}

main "$@"
